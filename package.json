{
  "name": "@codex/gost",
  "version": "1.0.0",
  "description": "GOST 7.32 document generation utilities for docx and xlsx",
  "exports": {
    "./docx": {
      "require": "./dist/docx-gost.js",
      "types": "./dist/docx-gost.d.ts"
    },
    "./excel": {
      "require": "./dist/excel-gost.js",
      "types": "./dist/excel-gost.d.ts"
    }
  },
  "files": ["dist", "README.md"],
  "engines": { "node": ">=18" },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "docx": "^9.6.1",
    "exceljs": "^4.4.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
